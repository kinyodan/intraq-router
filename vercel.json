{
  "rewrites": [
    {
      "source": "/dashboard",
      "destination": "https://intraq-dashboard.vercel.app/dashboard/"
    },
    {
      "source": "/dashboard/:match*",
      "destination": "https://intraq-dashboard.vercel.app/dashboard/:match*"
    },
    {
      "source": "/:match*",
      "destination": "https://intraq-ui.vercel.app/:match*"
    }
  ]
}
