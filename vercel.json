{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "rewrites": [
    {
      "source": "/dashboard",
      "destination": "https://intraq-dashboard.vercel.app/"
    },
    {
      "source": "/dashboard/:path*",
      "destination": "https://intraq-dashboard.vercel.app/:path*"
    },
    {
      "source": "/dashboard/_nuxt/:path*",
      "destination": "https://intraq-dashboard.vercel.app/_nuxt/:path*"
    },
    {
      "source": "/dashboard/assets/:path*",
      "destination": "https://intraq-dashboard.vercel.app/assets/:path*"
    },
    {
      "source": "/",
      "destination": "https://intraq-ui.vercel.app/"
    },
    {
      "source": "/:path*",
      "destination": "https://intraq-ui.vercel.app/:path*"
    }
  ]
}
