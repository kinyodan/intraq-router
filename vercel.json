{
  "rewrites": [
    {
      "source": "/dashboard",
      "destination": "https://your-dashboard-vercel-app.vercel.app/"
    },
    {
      "source": "/dashboard/:match*",
      "destination": "https://your-dashboard-vercel-app.vercel.app/:match*"
    },
    {
      "source": "/:match*",
      "destination": "https://your-landing-vercel-app.vercel.app/:match*"
    }
  ]
}